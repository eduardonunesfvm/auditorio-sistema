# Configuracao do Banco de Dados
# Desenvolvimento local (PostgreSQL local):
DATABASE_URL=postgresql+psycopg2://postgres:2212@localhost:5432/auditorio_db
# Producao (Neon): configure DATABASE_URL com a string de conexao do Neon

# Seguranca JWT
# ALTERE ESSA CHAVE EM PRODUCAO! Use uma string aleatoria forte.
SECRET_KEY=sua-chave-secreta-super-segura-aqui

# Algoritmo de assinatura JWT
ALGORITHM=HS256

# Tempo de expiracao do token de acesso (em minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=30
