# Configuração do Banco de Dados
# Use a chave adequada para o seu ambiente (localhost para dev, servidor remoto para prod)
DATABASE_URL=postgresql+psycopg2://postgres:2212@localhost:5432/auditorio_db

# Segurança JWT
# ALTERE ESSA CHAVE EM PRODUÇÃO! Use uma string aleatória forte.
SECRET_KEY=sua-chave-secreta-super-segura-aqui

# Algoritmo de assinatura JWT
ALGORITHM=HS256

# Tempo de expiração do token de acesso (em minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=30
